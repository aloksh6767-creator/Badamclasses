NODE_ENV=production
PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/badamclasses?retryWrites=true&w=majority
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=https://YOUR_VERCEL_FRONTEND_URL

# Required for Razorpay checkout/payment confirmation.
RAZORPAY_KEY_ID=rzp_live_replace_me
RAZORPAY_KEY_SECRET=replace_me

# Required for admin AI banner, SEO, notices, MCQ, and current affairs suggestions.
OPENAI_API_KEY=sk-replace_me
OPENAI_MODEL=gpt-4o-mini

# Required for upload endpoints and generated poster/banner media.
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# Optional live-class status detection.
YOUTUBE_API_KEY=replace_me

# Optional current affairs automation.
CURRENT_AFFAIRS_CRON=0 7 * * *
CURRENT_AFFAIRS_TZ=Asia/Kolkata
NEWS_API_KEY=replace_me
NEWS_API_URL=https://newsapi.org/v2/top-headlines
NEWS_COUNTRY=in
NEWS_PAGE_SIZE=30

# Optional Telegram/admin alerts.
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me
TELEGRAM_ADMIN_CHAT_ID=replace_me
TELEGRAM_WEBHOOK_SECRET=replace_me

# Optional local/admin bootstrap. Use only if you intentionally want startup admin seeding.
LOCAL_ADMIN_EMAIL=
LOCAL_ADMIN_PASSWORD=
LOCAL_ADMIN_NAME=Admin
LOCAL_ADMIN_PHONE=

# Optional Twilio SMS for offline test result notifications.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
