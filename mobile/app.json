{
  "expo": {
    "name": "BadamClasses",
    "slug": "badamclasses-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "badamclasses",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07122a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.badamclasses.mobile"
    },
    "android": {
      "package": "com.badamclasses.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07122a"
      }
    },
    "plugins": ["expo-router", "expo-notifications"],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiUrl": "http://127.0.0.1:5000/api"
    }
  }
}
